      "bash:go build",
      "bash:go install",
      "bash:go mod download",
      "bash:go mod graph",
      "bash:go mod tidy -diff",
      "bash:cargo check",
      "bash:cargo test",
      "bash:cargo build",
      "bash:cargo fmt --check",
      "bash:cargo clippy",
      "bash:cargo metadata",
