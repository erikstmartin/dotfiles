{
  // oh-my-opencode-slim config — side-by-side with oh-my-opencode
  // To activate: change plugin in opencode.json from "oh-my-opencode@latest" to "oh-my-opencode-slim@latest"
  "preset": "copilot",
  "presets": {
    "copilot": {
      "orchestrator": {
        "model": "github-copilot/claude-sonnet-4.6",
        "skills": ["*"],
        "mcps": ["websearch"]
      },
      "oracle": {
        "model": "github-copilot/claude-opus-4.6",
        "variant": "high",
        "skills": ["systematic-debugging", "code-review-excellence"],
        "mcps": []
      },
      "explorer": {
        "model": "github-copilot/claude-haiku-4.5",
        "variant": "low",
        "skills": [],
        "mcps": []
      },
      "librarian": {
        "model": "github-copilot/claude-haiku-4.5",
        "variant": "low",
        "skills": [],
        "mcps": ["websearch", "context7", "grep_app"]
      },
      "designer": {
        "model": "github-copilot/gemini-2.5-pro",
        "variant": "medium",
        "skills": ["agent-browser"],
        "mcps": []
      },
      "fixer": {
        "model": "github-copilot/claude-sonnet-4.6",
        "variant": "low",
        "skills": ["systematic-debugging", "verification-before-completion", "deslop"],
        "mcps": []
      }
    }
  },
  "tmux": {
    "enabled": false
  },
  // Fallback chains: primary model -> copilot GPT -> free Zen model
  "fallback": {
    "enabled": true,
    "timeoutMs": 15000,
    "chains": {
      "orchestrator": [
        "github-copilot/claude-sonnet-4.6",
        "github-copilot/gpt-5.2-codex",
        "opencode/big-pickle"
      ],
      "oracle": [
        "github-copilot/claude-opus-4.6",
        "github-copilot/gpt-5.2-codex",
        "opencode/big-pickle"
      ],
      "explorer": [
        "github-copilot/claude-haiku-4.5",
        "github-copilot/gpt-5.1-codex",
        "opencode/big-pickle"
      ],
      "librarian": [
        "github-copilot/claude-haiku-4.5",
        "github-copilot/gpt-5.2-codex",
        "opencode/big-pickle"
      ],
      "designer": [
        "github-copilot/gemini-2.5-pro",
        "github-copilot/gpt-5.2-codex",
        "opencode/big-pickle"
      ],
      "fixer": [
        "github-copilot/claude-sonnet-4.6",
        "github-copilot/gpt-5.1-codex",
        "opencode/big-pickle"
      ]
    }
  },
  "lsp": {
    "markdown-lsp": {
      "command": ["mise", "exec", "--", "marksman", "server"],
      "extensions": [".md", ".mdx"]
    }
  }
}
