{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "plugin": [
    "oh-my-openagent",
    "@ramtinj95/opencode-tokenscope",
    "@slkiser/opencode-quota",
    "opencode-handoff",
    "opencode-snippets"
  ],
  "permission": {
    "bash": {
      "git *": "allow",
      "git commit *": "ask",
      "git commit": "ask",
      "git push *": "ask",
      "git push": "ask",
      "rm *": "ask",
      "sudo *": "ask",
      "kubectl delete *": "ask",
      "kubectl apply *": "ask",
      "kubectl patch *": "ask",
      "kubectl exec *": "ask",
      "terraform apply *": "ask",
      "terraform destroy *": "ask",
      "docker rm *": "ask",
      "docker rmi *": "ask",
      "docker stop *": "ask",
      "brew uninstall *": "ask",
      "npm uninstall *": "ask",
      "pip uninstall *": "ask",
      "cargo uninstall *": "ask",
      "gem uninstall *": "ask",
      "gofmt *": "allow",
      "go test *": "allow",
      "go vet *": "allow",
      "go list *": "allow",
      "go env *": "allow",
      "go build *": "allow",
      "go install *": "allow",
      "go mod download *": "allow",
      "go mod graph *": "allow",
      "go mod tidy -diff *": "allow",
      "cargo check *": "allow",
      "cargo test *": "allow",
      "cargo build *": "allow",
      "cargo fmt --check *": "allow",
      "cargo clippy *": "allow",
      "cargo metadata *": "allow",
      "npm run build:ts *": "allow",
      "npm run lint *": "allow",
      "npm run typecheck *": "allow",
      "npm install *": "allow",
      "npm test *": "allow",
      "npm run test *": "allow",
      "npm run dev *": "allow",
      "npm run build *": "allow",
      "tsc --noEmit *": "allow",
      "ts-node *": "allow",
      "npx jest *": "allow",
      "npx vitest *": "allow",
      "npx playwright test *": "allow",
      "npx eslint *": "allow",
      "npx prettier --check *": "allow",
      "npx tsc --noEmit *": "allow",
      "bundle exec rake -T *": "allow",
      "bundle exec rspec *": "allow",
      "bundle exec rubocop --format *": "allow",
      "ruby -c *": "allow",
      "ruby -w *": "allow",
      "pytest *": "allow",
      "python -m pytest *": "allow",
      "python -m compileall *": "allow",
      "mypy *": "allow",
      "ruff check *": "allow",
      "pylint *": "allow",
      "dotnet build *": "allow",
      "dotnet test *": "allow",
      "dotnet restore *": "allow",
      "dotnet list *": "allow",
      "dotnet --info *": "allow",
      "flutter analyze *": "allow",
      "flutter test *": "allow",
      "flutter doctor *": "allow",
      "flutter pub deps *": "allow",
      "flutter pub outdated *": "allow",
      "dart analyze *": "allow",
      "dart test *": "allow",
      "dart pub deps *": "allow",
      "dart pub outdated *": "allow",
      "dart compile *": "allow",
      "terraform init -backend=false *": "allow",
      "terraform validate *": "allow",
      "terraform fmt -check *": "allow",
      "terraform providers *": "allow",
      "terraform plan *": "allow",
      "terraform graph *": "allow",
      "terraform show *": "allow",
      "terraform state list *": "allow",
      "terraform state show *": "allow",
      "kubectl get *": "allow",
      "kubectl describe *": "allow",
      "kubectl logs *": "allow",
      "kubectl top *": "allow",
      "kubectl version *": "allow",
      "kubectl cluster-info *": "allow",
      "kubectl config view *": "allow",
      "kubectl config get-contexts *": "allow",
      "kubectl config current-context *": "allow",
      "kubectl api-resources *": "allow",
      "kubectl api-versions *": "allow",
      "kubectl explain *": "allow",
      "kubectl auth can-i *": "allow",
      "helm version *": "allow",
      "helm list *": "allow",
      "helm status *": "allow",
      "helm get *": "allow",
      "kubectx *": "allow",
      "kubens *": "allow",
      "make *": "allow",
      "sqlc *": "allow",
      "rg *": "allow"
    },
    "read": {
      "~/.agents/skills/*": "allow"
    },
    "external_directory": {
      "~/.agents/skills/*": "allow"
    }
  },
  "mcp": {
    "godot": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@ryanmazzolini/minimal-godot-mcp"
      ],
      "environment": {
        "GODOT_WORKSPACE_PATH": "/Users/erikstmartin/Code/slipmat/godot",
        "GODOT_LSP_PORT": "6005"
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  }
}
