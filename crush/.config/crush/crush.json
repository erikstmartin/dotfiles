{
  "$schema": "https://charm.sh/crush/config.json",
  "skills_paths": [
    "~/.agents/skills",
    "~/.claude/skills",
    "~/.config/crush/skills"
  ],
  "options": {
    "tui": {
      "transparent": true
    }
  },
  "permissions": {
